{
  "name": "alwayssaved-fe-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "format-staged": "git ls-files --modified --others --exclude-standard | grep -E '\\.(js|jsx|ts|tsx|json|css|scss|md)$' | xargs npx prettier --write",
    "start": "next start",
    "aws-deploy": "next start -p 3000 -H 0.0.0.0",
    "lint": "eslint . && npm run format-staged",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.817.0",
    "@aws-sdk/client-sqs": "^3.817.0",
    "@aws-sdk/client-ssm": "^3.821.0",
    "@aws-sdk/s3-request-presigner": "^3.817.0",
    "@clerk/nextjs": "^7.5.17",
    "@heroui/react": "^2.7.9",
    "@qdrant/js-client-rest": "^1.14.1",
    "dayjs": "^1.11.13",
    "framer-motion": "^12.16.0",
    "mongoose": "^8.15.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-dropzone": "^14.3.8",
    "react-hot-toast": "^2.5.2",
    "react-virtualized": "^9.22.6",
    "sharp": "^0.35.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-virtualized": "^9.22.2",
    "@types/react-window": "^1.8.8",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
